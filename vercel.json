{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "NEXT_PUBLIC_VERCEL_ENV": "production"
  },
  "functions": {},
  "routes": [
    {
      "src": "tests/api/settle-early-exit.test.ts",
      "dest": "/api/tests"
    }
  ]
}
